{
  "name": "Quantum Dark",
  "type": "dark",
  "colors": {
    // Quantum Brand Colors
    "activityBar.background": "#0d1117",
    "activityBar.foreground": "#58a6ff",
    "activityBar.inactiveForeground": "#8b949e",
    "activityBarBadge.background": "#238636",
    "activityBarBadge.foreground": "#ffffff",

    // Editor
    "editor.background": "#0d1117",
    "editor.foreground": "#c9d1d9",
    "editor.lineHighlightBackground": "#161b22",
    "editor.selectionBackground": "#264f78",
    "editorCursor.foreground": "#58a6ff",
    "editorLineNumber.foreground": "#8b949e",
    "editorLineNumber.activeForeground": "#c9d1d9",

    // Sidebar
    "sideBar.background": "#0d1117",
    "sideBar.foreground": "#c9d1d9",
    "sideBarSectionHeader.background": "#161b22",

    // Tabs
    "tab.activeBackground": "#0d1117",
    "tab.inactiveBackground": "#161b22",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveForeground": "#8b949e",
    "tab.border": "#30363d",

    // Status bar
    "statusBar.background": "#161b22",
    "statusBar.foreground": "#c9d1d9",
    "statusBarItem.activeBackground": "#238636",
    "statusBarItem.hoverBackground": "#21262d",

    // Quantum accent colors
    "focusBorder": "#58a6ff",
    "foreground": "#c9d1d9",
    "errorForeground": "#f85149",
    "warningForeground": "#d29922",
    "infoForeground": "#58a6ff",

    // Buttons
    "button.background": "#238636",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#2ea043",
    "button.secondaryBackground": "#21262d",
    "button.secondaryForeground": "#c9d1d9",

    // Inputs
    "input.background": "#0d1117",
    "input.border": "#30363d",
    "input.foreground": "#c9d1d9",
    "input.placeholderForeground": "#8b949e",
    "inputValidation.errorBorder": "#f85149",
    "inputValidation.warningBorder": "#d29922",
    "inputValidation.infoBorder": "#58a6ff",

    // Dropdown
    "dropdown.background": "#0d1117",
    "dropdown.border": "#30363d",
    "dropdown.foreground": "#c9d1d9",

    // List
    "list.activeSelectionBackground": "#264f78",
    "list.activeSelectionForeground": "#ffffff",
    "list.hoverBackground": "#21262d",
    "list.inactiveSelectionBackground": "#161b22",

    // Scrollbar
    "scrollbarSlider.background": "#484f58",
    "scrollbarSlider.hoverBackground": "#6e7681",
    "scrollbarSlider.activeBackground": "#6e7681",

    // Git
    "gitDecoration.addedResourceForeground": "#3fb950",
    "gitDecoration.modifiedResourceForeground": "#d29922",
    "gitDecoration.deletedResourceForeground": "#f85149",
    "gitDecoration.untrackedResourceForeground": "#8b949e",

    // Title bar
    "titleBar.activeBackground": "#0d1117",
    "titleBar.activeForeground": "#c9d1d9",
    "titleBar.inactiveBackground": "#161b22",
    "titleBar.inactiveForeground": "#8b949e"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#8b949e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": "type",
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": "constant",
      "settings": {
        "foreground": "#79c0ff"
      }
    }
  ]
}